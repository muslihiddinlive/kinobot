# ─────────────────────────────────────────────────────
# YoqolganRobot — Sozlamalar namunasi
# Bu faylni nusxa olib .env deb saqlang: cp .env.example .env
# Render'da: Dashboard → Environment → shu qiymatlarni qo'lda kiriting
# ─────────────────────────────────────────────────────

# Bot token (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# Superadmin Telegram ID (@userinfobot dan oling)
SUPERADMIN_ID=your_telegram_id

# Qo'shimcha adminlar (vergul bilan), bo'sh qoldirsa SUPERADMIN_ID ishlatiladi
ADMIN_IDS=your_telegram_id

# Kino fayllar saqlanadigan supergroup ID (o'zingizning guruhingiz, botni admin qiling)
DB_GROUP_ID=your_supergroup_id

# ─── DATABASE YO'LI ───────────────────────────────────
# MUHIM: Host qilinganda DB yo'qolmasligi uchun:
#
# Railway:  Volumes → /data papkasi qo'shing → DB_PATH=/data/kinobot.db
# Render:   Disk qo'shing (Mount Path: /data) → DB_PATH=/data/kinobot.db
# VPS/cPanel: absolyut yo'l → DB_PATH=/home/user/kinobot/kinobot.db
#
# Oddiy local ishlatish uchun:
DB_PATH=kinobot.db

# ─── WEBHOOK ──────────────────────────────────────────
# Webhook domain (hosting domeningiz)
# Railway:  https://yourapp.up.railway.app
# Render:   https://yourapp.onrender.com
# cPanel:   https://yourdomain.com
# Bo'sh qoldirsangiz — polling rejimi ishlatiladi (local test uchun)
WEBHOOK_DOMAIN=https://yourapp.onrender.com

# Port (Railway/Render avtomatik o'rnatadi, cPanel uchun qo'lda)
PORT=8080
